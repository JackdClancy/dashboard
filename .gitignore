.vercel

# Local-only: Life OS spec snapshot (canonical copy lives in the Obsidian vault).
# Public repo — keep personal spec content out of git.
docs/

# Local Supabase creds for scripts/sync-goals.mjs
.env

# Sync shadow state (machine-written)
scripts/.sync-state-*.json

# Local whisper model for scripts/fetch-video.mjs (~148MB, re-downloadable)
scripts/.whisper/

# iOS Scriptable scripts live on the phone; hardcode the anon key, keep out of the public repo
scriptable/

# Bookmarklet snippet also hardcodes the anon key, same reason
bookmarklet/
.DS_Store

# Installed agent skills (third-party content, restorable via skills-lock.json + npx skills)
.agents/
.claude/skills/
